# Environment variables
PORT=3000

# Language: en for English, pt for Portuguese
BOT_LANGUAGE=pt

# URL for websocket connection (e.g., ngrok url without wss://)
SERVER=your_ngrok_domain.ngrok-free.app

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Optional: Set to true if you want to record the calls (requires Twilio SID and Auth Token)
RECORDING_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
